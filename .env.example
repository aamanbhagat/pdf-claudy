# Convert microservice on the VPS — consumed by app/api/convert/[op]/route.ts.
# Production: use the HTTPS sslip.io hostname (Caddy + Let's Encrypt on the VPS).
CONVERT_SERVICE_URL=https://104-214-176-55.sslip.io
CONVERT_SERVICE_TOKEN=your-convert-service-token

# DeepSeek API key for the AI tools (Summarizer, Translate). Server-side only.
# Optional: DEEPSEEK_MODEL (defaults to deepseek-chat → deepseek-v4-flash).
DEEPSEEK_API_KEY=your-deepseek-api-key
